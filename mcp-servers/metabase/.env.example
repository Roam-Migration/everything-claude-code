# Metabase MCP Server Configuration
# Copy this file to .env and fill in your values

# Your Metabase instance URL (without trailing slash)
METABASE_URL=https://your-instance.metabaseapp.com

# Metabase API Key (create in Settings → Admin → API Keys)
METABASE_API_KEY=your_api_key_here

# Database ID to query (find in Metabase Admin → Databases)
METABASE_DATABASE_ID=34
